#!/bin/sh

# Pre-push hook: gate on branch-aware validation.
# For pushes to main (deploy branch): run full release validation (CI + E2E).
# For other branches: run fast validation (style/audit/typecheck/unit/build).

REMOTE="$1"
EXIT_CODE=0

# Read stdin to detect if main is being pushed to.
# Each line has format: <local-ref> <local-sha> <remote-ref> <remote-sha>
IS_PUSHING_TO_MAIN=0
while read local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    IS_PUSHING_TO_MAIN=1
    break
  fi
done

if [ "$IS_PUSHING_TO_MAIN" = "1" ]; then
  npm run validate:release
  EXIT_CODE=$?
else
  npm run validate:ci
  EXIT_CODE=$?
fi

exit $EXIT_CODE
