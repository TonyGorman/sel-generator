{
  "name": "label-generator",
  "version": "1.0.4",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "main": "index.html",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && npm run build:bundle",
    "build:bundle": "vite build",
    "validate:ci": "npm run styles:types:check && npm run styles:audit && npm run test:run && npm run build:bundle",
    "validate:release": "npm run validate:ci && npm run audit:prod && npm run test:a11y && npm run test:e2e",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "preview": "vite preview",
    "prepare": "node scripts/setup-git-hooks.mjs",
    "styles:types": "node scripts/generate-css-module-types.mjs",
    "styles:types:check": "node scripts/generate-css-module-types.mjs --check",
    "styles:audit": "node scripts/audit-css-modules.mjs",
    "test": "vitest",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit",
    "test:run": "npm run typecheck && npm run test:unit",
    "test:a11y": "vitest run src/components/accessibility.test.tsx",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:visual": "playwright test tests/e2e/label-regressions.spec.ts",
    "test:visual:update": "playwright test tests/e2e/label-regressions.spec.ts --update-snapshots=all",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-barcode": "^1.6.1",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "pdfjs-dist": "^6.1.200",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.5",
    "vitest-axe": "^0.1.0"
  }
}
