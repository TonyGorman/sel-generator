{
  "name": "label-generator",
  "version": "1.0.4",
  "private": true,
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "main": "index.html",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && npm run build:bundle",
    "build:bundle": "vite build",
    "validate:ci": "npm run styles:types:check && npm run styles:audit && npm run typecheck && npm run test:unit && npm run build:bundle",
    "validate:release": "npm run validate:ci && npm run test:a11y && npm run test:e2e",
    "preview": "vite preview",
    "prepare": "node scripts/setup-git-hooks.mjs",
    "styles:types": "node scripts/generate-css-module-types.mjs",
    "styles:types:check": "node scripts/generate-css-module-types.mjs --check",
    "styles:audit": "node scripts/audit-css-modules.mjs",
    "test": "vitest",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit",
    "test:run": "npm run typecheck && npm run test:unit",
    "test:a11y": "vitest run src/components/accessibility.test.tsx",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:visual": "playwright test tests/e2e/label-regressions.spec.ts",
    "test:visual:update": "playwright test tests/e2e/label-regressions.spec.ts --update-snapshots=all",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "jsbarcode": "^3.12.1",
    "jspdf": "^4.2.1",
    "react": "^19.2.6",
    "react-barcode": "^1.6.1",
    "react-dom": "^19.2.6",
    "svg2pdf.js": "^2.7.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "axe-core": "^4.11.4",
    "jsdom": "^29.1.1",
    "pdfjs-dist": "^5.7.284",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5",
    "vitest-axe": "^0.1.0"
  }
}
